PORT=3001

# OpenRouter AI
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=google/gemini-flash-1.5

# Twitter/X
TWITTER_API_KEY=your_twitterapiio_key_here

# Email (SMTP)
